{
  "scopeName": "source.tiny",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#enums" },
    { "include": "#classes" },
    { "include": "#functions" },
    { "include": "#variables" },
    { "include": "#properties" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.tiny",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.tiny",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.tiny",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.interpolated.backtick.tiny",
          "begin": "`",
          "end": "`",
          "patterns": [
            {
              "name": "constant.character.escape.tiny",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.tiny",
              "begin": "\\$\\{",
              "end": "\\}",
              "patterns": [
                { "include": "#strings" },
                { "include": "#numbers" },
                { "include": "#keywords" },
                { "include": "#types" },
                { "include": "#properties" },
                { "include": "#functions" },
                { "include": "#variables" },
                { "include": "#operators" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.tiny",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.import.tiny",
          "match": "\\b(import|std|as|export)\\b"
        },
        {
          "name": "keyword.control.declaration.tiny",
          "match": "\\b(class|enum|embed|fn|let|const)\\b"
        },
        {
          "name": "keyword.control.flow.tiny",
          "match": "\\b(return|if|else|while|for|instanceof|in|match|break|continue)\\b"
        },
        {
          "name": "keyword.control.exception.tiny",
          "match": "\\b(try|catch|finally|throw)\\b"
        },
        {
          "name": "keyword.control.async.tiny",
          "match": "\\b(spawn|await)\\b"
        },
        {
          "name": "keyword.operator.word.tiny",
          "match": "\\b(and|or|typeof)\\b"
        },
        {
          "name": "constant.language.boolean.tiny",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.tiny",
          "match": "\\b(null|undefined)\\b"
        },
        {
          "name": "variable.language.this.tiny",
          "match": "\\bthis\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.tiny",
          "match": "\\b(string|number|bool|boolean|array|object|undefined|null|unknown|task|Task)\\b"
        },
        {
          "name": "entity.name.type.annotation.tiny",
          "match": "(?<=:\\s*)[a-zA-Z_][a-zA-Z0-9_]*(?:<[^>]+>)?"
        },
        {
          "name": "entity.name.type.generic.tiny",
          "match": "\\b[A-Z][a-zA-Z0-9_]*(?=\\s*<)"
        }
      ]
    },
    "classes": {
      "patterns": [
        {
          "name": "meta.class.tiny",
          "match": "\\bclass\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.type.class.tiny"
            }
          }
        },
        {
          "name": "entity.name.type.class.constructor.tiny",
          "match": "\\b[A-Z][a-zA-Z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "enums": {
      "patterns": [
        {
          "name": "meta.enum.tiny",
          "match": "\\benum\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.type.enum.tiny"
            }
          }
        },
        {
          "name": "constant.other.enum.member.tiny",
          "match": "(?<=\\.)[A-Z]?[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.declaration.tiny",
          "match": "\\bfn\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.function.tiny"
            }
          }
        },
        {
          "name": "entity.name.function.call.tiny",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.declaration.tiny",
          "match": "\\b(?:let|const)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "variable.other.declaration.tiny"
            }
          }
        },
        {
          "name": "variable.parameter.tiny",
          "match": "(?<=\\()\\s*[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*(,|\\)))"
        }
      ]
    },
    "properties": {
      "patterns": [
        {
          "name": "variable.other.property.tiny",
          "match": "(?<=\\.)[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "name": "variable.other.object.key.tiny",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*:)"
        },
        {
          "name": "variable.other.object.key.string.tiny",
          "match": "\"[^\"]+\"(?=\\s*:)"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.tiny",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.tiny",
          "match": "(=|\\+=|-=|\\*=|/=)"
        },
        {
          "name": "keyword.operator.arithmetic.tiny",
          "match": "(\\+\\+|--|\\+|-|\\*|/|%)"
        },
        {
          "name": "punctuation.accessor.tiny",
          "match": "\\."
        },
        {
          "name": "punctuation.separator.tiny",
          "match": "(,|:|;)"
        },
        {
          "name": "punctuation.bracket.tiny",
          "match": "(\\{|\\}|\\(|\\)|\\[|\\])"
        },
        {
          "name": "keyword.operator.arrow.tiny",
          "match": "=>"
        }
      ]
    }
  }
}