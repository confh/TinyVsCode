{
  "scopeName": "source.tiny",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#enums" },
    { "include": "#classes" },
    { "include": "#functions" },
    { "include": "#fields" },
    { "include": "#variables" },
    { "include": "#properties" },
    { "include": "#operators" }
  ],
  "repository": {
    "expression": {
      "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#enums" },
        { "include": "#classes" },
        { "include": "#functions" },
        { "include": "#fields" },
        { "include": "#variables" },
        { "include": "#properties" },
        { "include": "#operators" }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.tiny",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.tiny",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.tiny",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.tiny",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.tiny",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.interpolated.backtick.tiny",
          "begin": "`",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.tiny" }
          },
          "end": "`",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.tiny" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.tiny",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.tiny",
              "begin": "\\$\\{",
              "beginCaptures": {
                "0": { "name": "punctuation.section.interpolation.begin.tiny" }
              },
              "end": "\\}",
              "endCaptures": {
                "0": { "name": "punctuation.section.interpolation.end.tiny" }
              },
              "contentName": "source.tiny.embedded.expression",
              "patterns": [
                { "include": "#expression" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.tiny",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.tiny",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.import.tiny",
          "match": "\\b(import|std|as|export)\\b"
        },
        {
          "name": "keyword.control.declaration.tiny",
          "match": "\\b(class|enum|embed|fn|let|const|namespace)\\b"
        },
        {
          "name": "keyword.control.flow.tiny",
          "match": "\\b(return|if|else|while|for|instanceof|in|match|break|continue|field|private|public)\\b"
        },
        {
          "name": "keyword.control.exception.tiny",
          "match": "\\b(try|catch|finally|throw)\\b"
        },
        {
          "name": "keyword.control.async.tiny",
          "match": "\\b(spawn|await)\\b"
        },
        {
          "name": "keyword.operator.word.tiny",
          "match": "\\b(and|or|typeof)\\b"
        },
        {
          "name": "constant.language.boolean.tiny",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.tiny",
          "match": "\\b(null|undefined)\\b"
        },
        {
          "name": "variable.language.this.tiny",
          "match": "\\bthis\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.tiny",
          "match": "\\b(string|number|bool|boolean|array|object|any|unknown|void|undefined|null|error|task|Task)\\b"
        },
        {
          "name": "meta.type.annotation.tiny",
          "match": "(:)\\s*([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)?(?:<[^>]+>)?)",
          "captures": {
            "1": { "name": "punctuation.separator.type.tiny" },
            "2": { "name": "entity.name.type.annotation.tiny" }
          }
        },
        {
          "name": "entity.name.type.generic.tiny",
          "match": "\\b[A-Z][A-Za-z0-9_]*(?=\\s*<)"
        }
      ]
    },
    "classes": {
      "patterns": [
        {
          "name": "meta.class.tiny",
          "match": "\\bclass\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.type.class.tiny" }
          }
        },
        {
          "name": "entity.name.type.class.constructor.tiny",
          "match": "\\b[A-Z][A-Za-z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "enums": {
      "patterns": [
        {
          "name": "meta.enum.tiny",
          "match": "\\benum\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.type.enum.tiny" }
          }
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.declaration.tiny",
          "match": "\\bfn\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.function.tiny" }
          }
        },
        {
          "name": "entity.name.function.method-call.tiny",
          "match": "(?<=\\.)[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()"
        },
        {
          "name": "entity.name.function.call.tiny",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "fields": {
      "patterns": [
        {
          "name": "meta.field.declaration.tiny",
          "match": "\\bfield\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "variable.other.field.declaration.tiny" }
          }
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "meta.variable.declaration.tiny",
          "match": "\\b(?:let|const)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "variable.other.declaration.tiny" }
          }
        },
        {
          "name": "variable.parameter.tiny",
          "match": "(?<=\\()\\s*[A-Za-z_][A-Za-z0-9_]*(?=\\s*(,|\\)|:))"
        },
        {
          "name": "variable.other.read.tiny",
          "match": "\\b(?!import|std|as|export|class|enum|embed|fn|let|const|return|if|else|while|for|instanceof|in|match|break|continue|field|private|public|try|catch|finally|throw|spawn|await|and|or|typeof|true|false|null|undefined|this\\b)[a-z_][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "properties": {
      "patterns": [
        {
          "name": "variable.other.property.tiny",
          "match": "(?<=\\.)[A-Za-z_][A-Za-z0-9_]*"
        },
        {
          "name": "variable.other.object.key.tiny",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*:)"
        },
        {
          "name": "variable.other.object.key.string.tiny",
          "match": "\"[^\"]+\"(?=\\s*:)"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.tiny",
          "match": "=>"
        },
        {
          "name": "keyword.operator.nullish-coalescing.tiny",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.comparison.tiny",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.tiny",
          "match": "(\\+=|-=|\\*=|/=|=)"
        },
        {
          "name": "keyword.operator.arithmetic.tiny",
          "match": "(\\+\\+|--|\\+|-|\\*|/|%)"
        },
        {
          "name": "punctuation.accessor.tiny",
          "match": "\\."
        },
        {
          "name": "punctuation.separator.tiny",
          "match": "(,|:|;)"
        },
        {
          "name": "punctuation.bracket.tiny",
          "match": "(\\{|\\}|\\(|\\)|\\[|\\])"
        }
      ]
    }
  }
}
